{
  "$schema": "https://schema.zeabur.app/zeabur.json",
  "build": {
    "type": "prebuilt-image",
    "image": "eceasy/cli-proxy-api:latest"
  },
  "ports": [8317],
  "env": {
    "DEPLOY": {
      "default": "",
      "expose": true
    }
  },
  "configs": [
    "/CLIProxyAPI/config.yaml"
  ],
  "volumes": [
    {
      "id": "auth-data",
      "dir": "/root/.cli-proxy-api"
    },
    {
      "id": "logs",
      "dir": "/CLIProxyAPI/logs"
    }
  ]
}
